# OR Planer - API Keys
# Copy this file to .env and fill in your keys

# ── PRIMARY: Google Gemini (free, 20 images/day) ──────────────────────────────
# Get free key: https://aistudio.google.com/
GOOGLE_API_KEY=your-gemini-key-here

# ── FALLBACK 1: Anthropic Claude (paid, ~$0.001/image, best quality) ─────────
# Get key: https://console.anthropic.com/
# Recommended: add $5 credit → ~5000 images, never runs out in daily use
# ANTHROPIC_API_KEY=sk-ant-...

# ── FALLBACK 2: OpenRouter (free tier, slower) ────────────────────────────────
# Get free key: https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-...
